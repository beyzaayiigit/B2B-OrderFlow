# TextileFlow API — kopyala: backend/api/.env
# Google AI Studio'dan alınır: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Varsayılan model (istenirse değiştirilebilir)
GEMINI_MODEL=gemini-2.5-flash

# CORS — Flutter web origin'i (virgülle çoklu). Boş = tümü (yalnızca demo).
ALLOWED_ORIGINS=*
