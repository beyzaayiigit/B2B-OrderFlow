# Frontend (Flutter) — copy to frontend/.env
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

STORAGE_QUOTA_BYTES=1073741824

# LLM asistanı  — FastAPI servisinin adresi.
# Tanımlıysa "AI ile düzenle" butonları görünür; boşsa uygulama normal çalışır.
API_BASE_URL=http://localhost:8000

# Backend anahtarı backend/api/.env içinde tutulur (bkz. backend/api/.env.example):
GEMINI_API_KEY=...   
GEMINI_MODEL=gemini-2.5-flash
